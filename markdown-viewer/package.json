{
  "name": "markdown-viewer",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "bunx vite-node scripts/prebuild.ts",
    "build": "run-s prebuild type-check build-only",
    "preview": "VITE_STATIC_API=true vite preview",
    "build-only": "VITE_STATIC_API=true vite build",
    "type-check": "vue-tsc --build",
    "lint": "bun run format && eslint . --cache",
    "format": "prettier --write \"src/**/*.{ts,vue,css}\" \"vite-plugins/**/*.ts\" \"lib/**/*.ts\" \"scripts/**/*.ts\""
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1019.0",
    "@tailwindcss/vite": "4.2.2",
    "@types/dompurify": "3.2.0",
    "@types/marked": "6.0.0",
    "@vueuse/core": "14.2.1",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "dompurify": "3.3.3",
    "lucide-vue-next": "1.0.0",
    "marked": "17.0.5",
    "pinia": "3.0.4",
    "prismjs": "1.30.0",
    "reka-ui": "2.9.5",
    "tailwind-merge": "3.5.0",
    "tailwindcss": "4.2.2",
    "vue": "3.5.32",
    "vue-router": "5.0.4"
  },
  "devDependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "4.7.1",
    "@tsconfig/node24": "24.0.4",
    "@types/busboy": "1.5.4",
    "@types/node": "24.12.2",
    "@types/prismjs": "1.26.6",
    "@vercel/node": "5.7.4",
    "@vitejs/plugin-vue": "6.0.6",
    "@vitejs/plugin-vue-jsx": "5.1.5",
    "@vue/eslint-config-typescript": "14.7.0",
    "@vue/tsconfig": "0.9.1",
    "busboy": "1.6.0",
    "eslint": "10.2.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-better-tailwindcss": "4.4.1",
    "eslint-plugin-import-x": "4.16.2",
    "eslint-plugin-promise": "7.2.1",
    "eslint-plugin-regexp": "3.1.0",
    "eslint-plugin-security": "4.0.0",
    "eslint-plugin-sonarjs": "4.0.2",
    "eslint-plugin-unicorn": "64.0.0",
    "eslint-plugin-unused-imports": "4.4.1",
    "eslint-plugin-vue": "10.8.0",
    "jiti": "2.6.1",
    "npm-run-all2": "8.0.4",
    "prettier": "3.8.2",
    "prettier-plugin-tailwindcss": "0.7.2",
    "tw-animate-css": "1.4.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.58.1",
    "vite": "7.3.2",
    "vite-plugin-vue-devtools": "8.1.1",
    "vue-tsc": "3.2.6"
  },
  "overrides": {
    "smol-toml": "1.6.1",
    "minimatch": "10.2.5",
    "path-to-regexp": "6.3.0",
    "undici": "7.24.6"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
